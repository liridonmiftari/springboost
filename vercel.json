{
    "version": 2,
    "builds": [
      {
        "src": "server/index.cjs",
        "use": "@vercel/node"
      },
      {
        "src": "client/package.json",
        "use": "@vercel/static-build",
        "config": { "distDir": "dist" }
      }
    ],
    "rewrites": [
      {
        "source": "/api/(.*)",
        "destination": "server/index.cjs"
      },
      {
        "source": "/(.*)",
        "destination": "client/index.html"
      }
    ]
  }
  